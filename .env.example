# Optional comma-separated CORS allow-list for the backend.
# The default is "*" for localhost-oriented development.
KB_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional default knowledge-base root.
# If unset, the dev runner sets this to the repository root.
KB_DEFAULT_ROOT=/absolute/path/to/your/neunote-library
